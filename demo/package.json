{
  "name": "@ferrucc-io/emoji-picker-demo",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "bunx --bun vite",
    "build:types": "bunx --bun tsc",
    "build:stats": "bun run scripts/updateNpmStats.ts",
    "build": "bun run build:stats && bun run build:types && bunx --bun vite build && bun run scripts/prerender.ts",
    "preview": "bunx --bun vite preview",
    "deploy": "gh-pages -d dist",
    "lint": "bunx --bun oxlint .",
    "format": "bunx --bun prettier --write .",
    "format:check": "bunx --bun prettier --check ."
  },
  "dependencies": {
    "@ferrucc-io/emoji-picker": "workspace:*",
    "@tanstack/react-router": "^1.170.10",
    "prism-react-renderer": "^2.3.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.2.17",
    "@types/react-copy-to-clipboard": "^5.0.7",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "gh-pages": "^6.1.1",
    "oxlint": "^1.69.0",
    "prettier": "^3.2.5",
    "tailwindcss": "^4.1.14",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-oxlint": "^2.1.2"
  },
  "resolutions": {
    "@types/react": "18.2.0",
    "@types/react-dom": "18.2.0"
  }
}
